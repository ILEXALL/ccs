rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function currentUserData() {
      return userDoc(currentUid()).data;
    }

    function isNotBanned() {
      let data = currentUserData();
      return data.get('banned', false) != true
        || (
          data.get('bannedUntil', null) is timestamp
          && data.bannedUntil < request.time
        );
    }

    function isActiveUser() {
      return isSignedIn()
        && currentUserData().get('deleted', false) != true
        && isNotBanned();
    }

    function isAdmin() {
      return isActiveUser() && currentUserData().get('role', 'user') == 'admin';
    }

    function isModerator() {
      return isActiveUser()
        && currentUserData().get('role', 'user') == 'moderator';
    }

    function isStaff() {
      return isAdmin() || isModerator();
    }

    function isVerifiedOrStaff() {
      return isActiveUser()
        && (
          isStaff()
          || currentUserData().get('verified', false) == true
        );
    }

    function isOwner(userId) {
      return isSignedIn() && currentUid() == userId;
    }

    function isAdminUid(userId) {
      let data = userDoc(userId).data;
      return data.get('role', 'user') == 'admin'
        && data.get('deleted', false) != true
        && data.get('banned', false) != true;
    }

    function validUsername(username) {
      return username is string
        && username.size() >= 3
        && username.size() <= 30
        && username.matches('^[a-zA-Z0-9_]+$');
    }

    function validUsernameKey(username, usernameKey) {
      return usernameKey is string
        && usernameKey == username.lower()
        && usernameKey.matches('^[a-z0-9_]{3,30}$');
    }

    function usernameReservationOwnedBy(userId, username, usernameKey) {
      let reservation = get(
        /databases/$(database)/documents/usernames/$(usernameKey)
      );
      return validUsername(username)
        && validUsernameKey(username, usernameKey)
        && reservation.data.uid == userId
        && reservation.data.username == username
        && reservation.data.usernameKey == usernameKey;
    }

    function validUsernameReservation(usernameKey) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'usernameKey',
          'updatedAt'
        ])
        && request.resource.data.uid == currentUid()
        && validUsername(request.resource.data.username)
        && validUsernameKey(request.resource.data.username, usernameKey)
        && request.resource.data.usernameKey == usernameKey
        && request.resource.data.updatedAt == request.time;
    }

    function selfUsernameValidOrUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'username',
          'usernameKey'
        ])
        || usernameReservationOwnedBy(
          currentUid(),
          request.resource.data.username,
          request.resource.data.usernameKey
        );
    }

    function validMaintenanceConfig() {
      return request.resource.data.keys().hasOnly([
          'maintenanceEnabled',
          'maintenanceTitle',
          'maintenanceMessage',
          'allowAdminBypass'
        ])
        && request.resource.data.maintenanceEnabled is bool
        && request.resource.data.maintenanceTitle is string
        && request.resource.data.maintenanceTitle.size() <= 100
        && request.resource.data.maintenanceMessage is string
        && request.resource.data.maintenanceMessage.size() <= 500
        && request.resource.data.allowAdminBypass is bool;
    }

    function selfUserEditableKeys() {
      return [
        'uid',
        'name',
        'username',
        'usernameKey',
        'email',
        'photoUrl',
        'bio',
        'avatarPath',
        'city',
        'country',
        'settings',
        'garage',
        'provider',
        'telegramUsername',
        'instagram',
        'tiktok',
        'telegram',
        'reviewNotifications',
        'likeNotifications',
        'commentNotifications',
        'newSpotNotifications',
        'newMessageNotifications',
        'publicProfile',
        'showGarage',
        'fcmTokens',
        'fcmTokenUpdatedAt',
        'lastFcmTokenPlatform',
        'isOnline',
        'lastSeenAt',
        'isSharingLiveLocation',
        'liveLocationExpiresAt',
        'liveLocationShareDurationMinutes',
        'liveLocationVisibleToUserIds',
        'blockedUserIds',
        'updatedAt'
      ];
    }

    function userProtectedFieldsUnchanged() {
      return request.resource.data.get('role', 'user')
          == resource.data.get('role', 'user')
        && request.resource.data.get('verified', false)
          == resource.data.get('verified', false)
        && request.resource.data.get('banned', false)
          == resource.data.get('banned', false)
        && request.resource.data.get('deleted', false)
          == resource.data.get('deleted', false)
        && request.resource.data.uid == resource.data.uid;
    }

    function validNewUser(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.email is string
        && usernameReservationOwnedBy(
          userId,
          request.resource.data.username,
          request.resource.data.usernameKey
        )
        && request.resource.data.get('role', 'user') == 'user'
        && request.resource.data.get('verified', false) != true
        && request.resource.data.get('banned', false) != true
        && request.resource.data.get('deleted', false) != true;
    }

    function moderatorCanUpdateUser() {
      return isModerator()
        && resource.data.get('role', 'user') == 'user'
        && request.resource.data.get('role', 'user')
          == resource.data.get('role', 'user')
        && request.resource.data.get('verified', false)
          == resource.data.get('verified', false)
        && request.resource.data.get('deleted', false)
          == resource.data.get('deleted', false)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'banned',
          'bannedUntil',
          'bannedByUid',
          'bannedBy',
          'bannedAt',
          'unbannedByUid',
          'unbannedBy',
          'unbannedAt',
          'updatedAt'
        ]);
    }

    function canReadSpot() {
      return isActiveUser()
        && (
          isStaff()
          || resource.data.addedByUid == currentUid()
          || (
            resource.data.status == 'approved'
            && (
              resource.data.get('verifiedOnly', false) != true
              || isVerifiedOrStaff()
            )
          )
        );
    }

    function validNewSpot() {
      return request.resource.data.addedByUid == currentUid()
        && request.resource.data.name is string
        && request.resource.data.cityCountry is string
        && request.resource.data.categories is list
        && request.resource.data.status in ['pending', 'approved']
        && (
          request.resource.data.status == 'pending'
          || isStaff()
        )
        && (
          request.resource.data.get('verifiedOnly', false) != true
          || isVerifiedOrStaff()
        )
        && (
          isStaff()
          || (
            request.resource.data.get('ownerUid', '') == ''
            && request.resource.data.get('ownerUsername', '') == ''
            && request.resource.data.get('rating', 0) == 0
          )
        );
    }

    function ownerCanEditSpot() {
      return isActiveUser()
        && resource.data.addedByUid == currentUid()
        && request.resource.data.addedByUid == resource.data.addedByUid
        && request.resource.data.status == 'edited'
        && (
          request.resource.data.get('verifiedOnly', false) != true
          || isVerifiedOrStaff()
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'cityCountry',
          'description',
          'lat',
          'lng',
          'coordinates',
          'categories',
          'reelLink',
          'contactPhone',
          'contactInstagram',
          'contactEmail',
          'openingHours',
          'photoUrl',
          'photoUrls',
          'verifiedOnly',
          'isTemporary',
          'startsAt',
          'expiresAt',
          'showOnMapAt',
          'status',
          'editReviewStatus',
          'editChangeSummary',
          'editedBy',
          'editedByUid',
          'editedAt',
          'updatedAt'
        ]);
    }

    function businessOwnerCanEditSpot() {
      return isActiveUser()
        && resource.data.get('ownerUid', '') == currentUid()
        && request.resource.data.get('ownerUid', '')
          == resource.data.get('ownerUid', '')
        && request.resource.data.get('businessEditedByUid', '') == currentUid()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'contactPhone',
          'contactInstagram',
          'contactEmail',
          'openingHours',
          'businessEditedBy',
          'businessEditedByUid',
          'businessEditedAt',
          'updatedAt'
        ]);
    }

    function signedInUserCanRefreshSpotRating() {
      return isActiveUser()
        && request.resource.data.rating is number
        && request.resource.data.rating >= 0
        && request.resource.data.rating <= 5
        && request.resource.data.ratingCount is int
        && request.resource.data.ratingCount >= 0
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'rating',
          'ratingCount',
          'reviewCount',
          'reviewUpdatedAt',
          'updatedAt'
        ]);
    }

    function signedInUserCanUpdateSpotCounters() {
      return isActiveUser()
        && request.resource.data.get('likeCount', 0) is int
        && request.resource.data.get('likeCount', 0) >= 0
        && request.resource.data.get('commentCount', 0) is int
        && request.resource.data.get('commentCount', 0) >= 0
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'likeCount',
          'commentCount',
          'updatedAt'
        ]);
    }

    function listChangedOnlyByCurrentUser(before, after) {
      return after.toSet().difference(before.toSet()).hasOnly([currentUid()])
        && before.toSet().difference(after.toSet()).hasOnly([currentUid()]);
    }

    function policeReportIdentityUnchanged() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.username == resource.data.username
        && request.resource.data.lat == resource.data.lat
        && request.resource.data.lng == resource.data.lng
        && request.resource.data.coordinates == resource.data.coordinates
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.expiresAt == resource.data.expiresAt;
    }

    function policeReportRemovalAllowed() {
      return request.resource.data.status != 'removed'
        || resource.data.uid == currentUid()
        || isStaff()
        || (
          currentUid() in request.resource.data.notThereBy
          && request.resource.data.notThereBy.size() >= 3
        );
    }

    function validNewSosReport(reportId) {
      return reportId == currentUid()
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'description',
          'reason',
          'lat',
          'lng',
          'coordinates',
          'createdAt',
          'expiresAt',
          'updatedAt',
          'confirmationRequestedAt',
          'status'
        ])
        && request.resource.data.uid == currentUid()
        && request.resource.data.username is string
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 12
        && request.resource.data.description.size() <= 500
        && request.resource.data.reason in [
          'battery',
          'tire',
          'fuel',
          'towing',
          'breakdown',
          'other'
        ]
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.lat >= -90
        && request.resource.data.lat <= 90
        && request.resource.data.lng >= -180
        && request.resource.data.lng <= 180
        && request.resource.data.coordinates is latlng
        && request.resource.data.createdAt == request.time
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.expiresAt
          <= request.time + duration.value(13, 'h')
        && request.resource.data.updatedAt == request.time
        && request.resource.data.get('confirmationRequestedAt', null) == null
        && request.resource.data.status == 'active';
    }

    function ownerCanRestartSos(reportId) {
      return isActiveUser()
        && resource.data.uid == currentUid()
        && validNewSosReport(reportId)
        && (
          (
            resource.data.status == 'removed'
            && resource.data.updatedAt is timestamp
            && resource.data.updatedAt + duration.value(1, 'm') <= request.time
          )
          || (
            resource.data.expiresAt is timestamp
            && resource.data.expiresAt <= request.time
          )
        );
    }

    function isFriendRequestParticipant() {
      return isSignedIn()
        && (
          resource.data.fromUid == currentUid()
          || resource.data.toUid == currentUid()
          || isAdmin()
        );
    }

    function isFriendshipParticipant() {
      return isSignedIn()
        && (
          currentUid() in resource.data.userIds
          || isAdmin()
        );
    }

    function friendshipAccepted(firstUid, secondUid) {
      return (
        existsAfter(
          /databases/$(database)/documents/friend_requests/$(firstUid + '_' + secondUid)
        )
        && getAfter(
          /databases/$(database)/documents/friend_requests/$(firstUid + '_' + secondUid)
        ).data.status == 'accepted'
      ) || (
        existsAfter(
          /databases/$(database)/documents/friend_requests/$(secondUid + '_' + firstUid)
        )
        && getAfter(
          /databases/$(database)/documents/friend_requests/$(secondUid + '_' + firstUid)
        ).data.status == 'accepted'
      );
    }

    function chatData(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId)).data;
    }

    function isChatMember(chatId) {
      return isSignedIn()
        && chatExists(chatId)
        && currentUid() in chatData(chatId).memberIds;
    }

    function chatExists(chatId) {
      return exists(/databases/$(database)/documents/chats/$(chatId));
    }

    function chatOwnerUid(chatId) {
      let data = chatData(chatId);
      return data.get('ownerUid', data.memberIds[0]);
    }

    function isChatOwner(chatId) {
      return isSignedIn() && currentUid() == chatOwnerUid(chatId);
    }

    function isChatModerator(chatId) {
      return isSignedIn()
        && currentUid() in chatData(chatId).get('moderatorIds', []);
    }

    function canManageChat(chatId) {
      return isChatOwner(chatId) || isChatModerator(chatId) || isStaff();
    }

    function chatMembershipUnchanged() {
      return request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == resource.data.memberIds.size()
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && resource.data.memberIds.hasAll(request.resource.data.memberIds)
        && request.resource.data.isGroup == resource.data.isGroup;
    }

    function userBlocks(blockerUid, blockedUid) {
      return blockedUid in get(
        /databases/$(database)/documents/users/$(blockerUid)
      ).data.get('blockedUserIds', []);
    }

    function directMemberIdsBlocked(memberIds) {
      return memberIds is list
        && memberIds.size() == 2
        && (
          userBlocks(memberIds[0], memberIds[1])
          || userBlocks(memberIds[1], memberIds[0])
        );
    }

    function directChatBlocked(chatId) {
      let data = chatData(chatId);
      return data.get('isGroup', false) != true
        && directMemberIdsBlocked(data.memberIds);
    }

    function notificationTargetsSpotOwner() {
      let spot = get(
        /databases/$(database)/documents/spots/$(request.resource.data.spotId)
      ).data;
      return request.resource.data.userId == spot.addedByUid
        || request.resource.data.userId == spot.get('ownerUid', '');
    }

    function validSpotLikeNotification() {
      let data = request.resource.data;
      return data.type == 'spot_like'
        && data.spotId is string
        && exists(/databases/$(database)/documents/spots/$(data.spotId))
        && notificationTargetsSpotOwner()
        && exists(
          /databases/$(database)/documents/spot_likes/$(data.spotId + '_' + currentUid())
        );
    }

    function validSpotCommentNotification() {
      let data = request.resource.data;
      let review = get(
        /databases/$(database)/documents/spot_reviews/$(data.reviewId)
      ).data;
      return data.type == 'spot_comment'
        && data.spotId is string
        && data.reviewId is string
        && exists(/databases/$(database)/documents/spots/$(data.spotId))
        && exists(/databases/$(database)/documents/spot_reviews/$(data.reviewId))
        && review.userId == currentUid()
        && review.spotId == data.spotId
        && notificationTargetsSpotOwner();
    }

    function validChatMessageNotification() {
      let data = request.resource.data;
      return data.type == 'chat_message'
        && data.chatId is string
        && currentUid() in chatData(data.chatId).memberIds
        && data.userId in chatData(data.chatId).memberIds;
    }

    function validFriendRequestNotification() {
      let data = request.resource.data;
      return data.type == 'friend_request'
        && data.friendRequestId is string
        && data.fromUid == currentUid()
        && exists(
          /databases/$(database)/documents/friend_requests/$(data.friendRequestId)
        )
        && get(
          /databases/$(database)/documents/friend_requests/$(data.friendRequestId)
        ).data.fromUid == currentUid()
        && get(
          /databases/$(database)/documents/friend_requests/$(data.friendRequestId)
        ).data.toUid == data.userId
        && get(
          /databases/$(database)/documents/friend_requests/$(data.friendRequestId)
        ).data.status == 'pending';
    }

    function validUserNotificationCreate() {
      let data = request.resource.data;
      return isActiveUser()
        && data.userId is string
        && data.userId != currentUid()
        && data.actorUserId == currentUid()
        && data.type is string
        && data.title is string
        && data.body is string
        && data.read == false
        && (
          isStaff()
          || validSpotLikeNotification()
          || validSpotCommentNotification()
          || validChatMessageNotification()
          || validFriendRequestNotification()
        );
    }

    match /app_config/{configId} {
      allow read: if configId == 'main';
      allow create, update: if configId == 'main'
        && isAdmin()
        && validMaintenanceConfig();
      allow delete: if configId == 'main' && isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && validNewUser(userId);
      allow update: if (
        isOwner(userId)
        && isActiveUser()
        && userProtectedFieldsUnchanged()
        && selfUsernameValidOrUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(selfUserEditableKeys())
      ) || isAdmin() || moderatorCanUpdateUser();
      allow delete: if isAdmin();
    }

    match /usernames/{usernameKey} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && validUsernameReservation(usernameKey);
      allow update: if isActiveUser()
        && resource.data.uid == currentUid()
        && validUsernameReservation(usernameKey)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid',
          'username',
          'usernameKey',
          'updatedAt'
        ]);
      allow delete: if isAdmin()
        || (isActiveUser() && resource.data.uid == currentUid());
    }

    match /spots/{spotId} {
      allow read: if canReadSpot();
      allow create: if isActiveUser() && validNewSpot();
      allow update: if isStaff()
        || ownerCanEditSpot()
        || businessOwnerCanEditSpot()
        || signedInUserCanRefreshSpotRating()
        || signedInUserCanUpdateSpotCounters();
      allow delete: if isStaff();
    }

    match /spot_reviews/{reviewId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser()
        && request.resource.data.userId == currentUid()
        && request.resource.data.spotId is string
        && request.resource.data.username is string
        && (
          request.resource.data.get('type', 'comment')
            in ['comment', 'rating']
        );
      allow update: if isActiveUser()
        && resource.data.userId == currentUid()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.spotId == resource.data.spotId
        && request.resource.data.username == resource.data.username
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'comment',
          'rating',
          'ratingDayKey',
          'edited',
          'updatedAt'
        ]);
      allow delete: if isActiveUser()
        && (resource.data.userId == currentUid() || isStaff());
    }

    match /spot_comment_daily_counts/{countId} {
      allow get: if isActiveUser();
      allow list: if false;
      allow create: if isActiveUser()
        && request.resource.data.userId == currentUid()
        && request.resource.data.spotId is string
        && request.resource.data.dayKey is string
        && request.resource.data.count is int
        && request.resource.data.count >= 1
        && request.resource.data.count <= 5
        && request.resource.data.keys().hasOnly([
          'spotId',
          'userId',
          'dayKey',
          'count',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if isActiveUser()
        && resource.data.userId == currentUid()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.spotId == resource.data.spotId
        && request.resource.data.dayKey == resource.data.dayKey
        && request.resource.data.count is int
        && request.resource.data.count >= resource.data.count
        && request.resource.data.count <= 5
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'count',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /spot_likes/{likeId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser()
        && request.resource.data.userId == currentUid()
        && (
          request.resource.data.get('spotId', '') != ''
          || request.resource.data.get('commentId', '') != ''
        );
      allow delete: if isActiveUser()
        && (resource.data.userId == currentUid() || isStaff());
      allow update: if false;
    }

    match /police_reports/{reportId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser()
        && request.resource.data.uid == currentUid()
        && request.resource.data.username is string
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.coordinates is latlng
        && request.resource.data.createdAt is timestamp
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.status == 'active'
        && request.resource.data.stillThereBy is list
        && request.resource.data.notThereBy is list
        && request.resource.data.stillThereBy.size() == 0
        && request.resource.data.notThereBy.size() == 0;
      allow update: if isActiveUser()
        && policeReportIdentityUnchanged()
        && request.resource.data.status in ['active', 'removed']
        && request.resource.data.stillThereBy is list
        && request.resource.data.notThereBy is list
        && listChangedOnlyByCurrentUser(
          resource.data.stillThereBy,
          request.resource.data.stillThereBy
        )
        && listChangedOnlyByCurrentUser(
          resource.data.notThereBy,
          request.resource.data.notThereBy
        )
        && policeReportRemovalAllowed()
        && (
          !request.resource.data.keys().hasAny(['removedByUid'])
          || request.resource.data.removedByUid == currentUid()
          || isStaff()
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'stillThereBy',
          'notThereBy',
          'updatedAt',
          'status',
          'removedByUid',
          'removedAt'
        ]);
      allow delete: if isStaff();
    }

    match /sos_reports/{reportId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser() && validNewSosReport(reportId);
      allow update: if ownerCanRestartSos(reportId)
        || (
          isActiveUser()
          && (resource.data.uid == currentUid() || isStaff())
          && resource.data.status == 'active'
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.username == resource.data.username
          && request.resource.data.lat == resource.data.lat
          && request.resource.data.lng == resource.data.lng
          && request.resource.data.coordinates == resource.data.coordinates
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.expiresAt == resource.data.expiresAt
          && request.resource.data.reason == resource.data.reason
          && request.resource.data.description == resource.data.description
          && request.resource.data.status in ['active', 'removed']
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'updatedAt',
            'confirmationRequestedAt',
            'removedByUid',
            'removedAt'
          ])
          && (
            !request.resource.data.keys().hasAny(['removedByUid'])
            || request.resource.data.removedByUid == currentUid()
            || isStaff()
          )
        );
      allow delete: if isStaff();
    }

    match /live_locations/{userId} {
      allow read: if isActiveUser()
        && (
          userId == currentUid()
          || isStaff()
          || currentUid() in resource.data.visibleToUserIds
          || '__public__' in resource.data.visibleToUserIds
        );
      allow create, update: if isOwner(userId)
        && isActiveUser()
        && request.resource.data.uid == currentUid()
        && request.resource.data.username is string
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.coordinates is latlng
        && request.resource.data.visibleToUserIds is list
        && currentUid() in request.resource.data.visibleToUserIds
        && request.resource.data.expiresAt is timestamp;
      allow delete: if isOwner(userId) || isStaff();
    }

    match /meet_notifications/{notificationId} {
      allow read: if isActiveUser()
        && resource.data.userId == currentUid();
      allow create: if isStaff()
        && request.resource.data.userId is string
        && request.resource.data.spotId is string
        && request.resource.data.spotName is string
        && request.resource.data.read == false;
      allow update: if isActiveUser()
        && resource.data.userId == currentUid()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.spotId == resource.data.spotId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'read',
          'readAt'
        ]);
      allow delete: if isStaff()
        || (isActiveUser() && resource.data.userId == currentUid());
    }

    match /admin_notifications/{notificationId} {
      allow read: if isActiveUser()
        && resource.data.userId == currentUid();
      allow create: if isActiveUser()
        && request.resource.data.userId is string
        && isAdminUid(request.resource.data.userId)
        && request.resource.data.type is string
        && request.resource.data.spotId is string
        && request.resource.data.spotName is string
        && request.resource.data.read == false
        && (
          isStaff()
          || (
            request.resource.data.type == 'spot_pending_review'
            && request.resource.data.addedByUid == currentUid()
          )
        );
      allow update: if isActiveUser()
        && resource.data.userId == currentUid()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.spotId == resource.data.spotId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'read',
          'readAt'
        ]);
      allow delete: if isStaff()
        || (isActiveUser() && resource.data.userId == currentUid());
    }

    match /user_notifications/{notificationId} {
      allow read: if isActiveUser()
        && resource.data.userId == currentUid();
      allow create: if validUserNotificationCreate();
      allow update: if isActiveUser()
        && resource.data.userId == currentUid()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'read',
          'readAt'
        ]);
      allow delete: if isStaff()
        || (isActiveUser() && resource.data.userId == currentUid());
    }

    match /project_news/{newsId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /friend_location_notifications/{notificationId} {
      allow read: if isActiveUser()
        && resource.data.userId == currentUid();
      allow create: if isActiveUser()
        && request.resource.data.userId == currentUid()
        && request.resource.data.friendUid is string
        && request.resource.data.friendUid != currentUid()
        && request.resource.data.friendUsername is string
        && request.resource.data.type in ['friend_nearby', 'friend_at_spot']
        && request.resource.data.read == false;
      allow update: if isActiveUser()
        && resource.data.userId == currentUid()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.friendUid == resource.data.friendUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'friendUsername',
          'friendName',
          'friendLat',
          'friendLng',
          'friendCoordinates',
          'type',
          'distanceMeters',
          'spotId',
          'spotName',
          'spotCategory',
          'read',
          'readAt',
          'lastNotifiedAtMillis',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if isStaff()
        || (isActiveUser() && resource.data.userId == currentUid());
    }

    match /friend_requests/{requestId} {
      allow read: if isFriendRequestParticipant();
      allow create: if isActiveUser()
        && request.resource.data.fromUid == currentUid()
        && request.resource.data.toUid is string
        && request.resource.data.toUid != currentUid()
        && request.resource.data.fromUsername is string
        && request.resource.data.toUsername is string
        && request.resource.data.status == 'pending';
      allow update: if isActiveUser()
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'respondedAt',
          'updatedAt'
        ])
        && (
          (
            resource.data.toUid == currentUid()
            && request.resource.data.status in ['accepted', 'declined']
          )
          || isStaff()
        );
      allow delete: if isActiveUser()
        && (
          resource.data.fromUid == currentUid()
          || resource.data.toUid == currentUid()
          || isStaff()
        );
    }

    match /friendships/{friendshipId} {
      allow read: if isFriendshipParticipant();
      allow create: if isActiveUser()
        && request.resource.data.userIds is list
        && request.resource.data.userIds.size() == 2
        && currentUid() in request.resource.data.userIds
        && friendshipAccepted(
          request.resource.data.userIds[0],
          request.resource.data.userIds[1]
        );
      allow update: if false;
      allow delete: if isFriendshipParticipant();
    }

    match /blocked_users/{blockId} {
      allow get: if isActiveUser()
        && (
          !exists(/databases/$(database)/documents/blocked_users/$(blockId))
          || resource.data.blockerUid == currentUid()
          || resource.data.blockedUid == currentUid()
        );
      allow list: if isActiveUser()
        && resource.data.blockerUid == currentUid();
      allow create: if isActiveUser()
        && request.resource.data.blockerUid == currentUid()
        && request.resource.data.blockedUid is string
        && request.resource.data.blockedUid != currentUid()
        && blockId == currentUid() + '_' + request.resource.data.blockedUid
        && request.resource.data.keys().hasOnly([
          'blockerUid',
          'blockedUid',
          'blockedUsername',
          'blockedName',
          'blockedPhotoUrl',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if isActiveUser()
        && resource.data.blockerUid == currentUid()
        && request.resource.data.blockerUid == resource.data.blockerUid
        && request.resource.data.blockedUid == resource.data.blockedUid
        && blockId == currentUid() + '_' + resource.data.blockedUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'blockerUid',
          'blockedUid',
          'blockedUsername',
          'blockedName',
          'blockedPhotoUrl',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if isActiveUser()
        && resource.data.blockerUid == currentUid();
    }

    match /chats/{chatId} {
      allow get: if isSignedIn()
        && (
          !chatExists(chatId)
          || currentUid() in resource.data.memberIds
        );
      allow list: if isSignedIn()
        && currentUid() in resource.data.memberIds;
      allow create: if isActiveUser()
        && request.resource.data.memberIds is list
        && currentUid() in request.resource.data.memberIds
        && request.resource.data.memberIds.size() >= 2
        && (
          request.resource.data.get('isGroup', false) == true
          || !directMemberIdsBlocked(request.resource.data.memberIds)
        );
      allow update: if isSignedIn()
        && currentUid() in resource.data.memberIds
        && !directChatBlocked(chatId)
        && (
          (
            chatMembershipUnchanged()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'name',
              'photoUrl',
              'avatarUrl',
              'description',
              'lastMessage',
              'lastSenderUid',
              'lastSenderUsername',
              'memberIds',
              'memberUsernames',
              'memberPhotoUrls',
              'updatedAt'
            ])
          )
          || (
            canManageChat(chatId)
            && request.resource.data.isGroup == resource.data.isGroup
            && request.resource.data.memberIds is list
            && request.resource.data.memberIds.hasAll(resource.data.memberIds)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'name',
              'photoUrl',
              'avatarUrl',
              'description',
              'memberIds',
              'memberUsernames',
              'memberPhotoUrls',
              'moderatorIds',
              'ownerUid',
              'lastMessage',
              'lastSenderUid',
              'lastSenderUsername',
              'updatedAt'
            ])
          )
        );
      allow delete: if isStaff();

      match /messages/{messageId} {
        allow read: if isChatMember(chatId);
        allow create: if isChatMember(chatId)
          && !directChatBlocked(chatId)
          && request.resource.data.senderUid == currentUid()
          && request.resource.data.senderUsername is string
          && request.resource.data.text is string;
        allow update: if isChatMember(chatId)
          && (
            resource.data.senderUid == currentUid()
            || canManageChat(chatId)
          )
          && request.resource.data.senderUid == resource.data.senderUid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'text',
            'edited',
            'updatedAt'
          ]);
        allow delete: if isChatMember(chatId)
          && (
            resource.data.senderUid == currentUid()
            || canManageChat(chatId)
          );
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
